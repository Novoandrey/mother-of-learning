export const dynamic = 'force-dynamic'

import { getCampaignBySlug } from '@/lib/campaign'
import { createClient } from '@/lib/supabase/server'
import { notFound } from 'next/navigation'
import Link from 'next/link'
import type { Metadata } from 'next'

export async function generateMetadata({
  params,
}: {
  params: Promise<{ slug: string }>
}): Promise<Metadata> {
  const { slug } = await params
  const campaign = await getCampaignBySlug(slug)
  return { title: campaign ? `Петли — ${campaign.name}` : 'Петли' }
}

export default async function LoopsPage({
  params,
  searchParams,
}: {
  params: Promise<{ slug: string }>
  searchParams: Promise<{ loop?: string }>
}) {
  const { slug } = await params
  const { loop: loopParam } = await searchParams
  const campaign = await getCampaignBySlug(slug)
  if (!campaign) notFound()

  const supabase = await createClient()

  const { data: loops } = await supabase
    .from('loops')
    .select('*')
    .eq('campaign_id', campaign.id)
    .order('number', { ascending: true })

  const currentLoop =
    loops?.find((l) => l.status === 'current') ?? loops?.[loops.length - 1] ?? null

  const selectedLoopNumber = loopParam ? parseInt(loopParam) : (currentLoop?.number ?? null)
  const selectedLoop = loops?.find((l) => l.number === selectedLoopNumber) ?? currentLoop

  const { data: sessions } = selectedLoop
    ? await supabase
        .from('sessions')
        .select('id, session_number, title, played_at, loop_number')
        .eq('campaign_id', campaign.id)
        .eq('loop_number', selectedLoop.number)
        .order('session_number', { ascending: false })
    : { data: [] }

  const { data: chronicles } = selectedLoop
    ? await supabase
        .from('chronicles')
        .select('id, title, game_date, node_id, nodes(title)')
        .eq('campaign_id', campaign.id)
        .eq('loop_number', selectedLoop.number)
        .order('created_at', { ascending: false })
        .limit(10)
    : { data: [] }

  const statusLabel: Record<string, { label: string; color: string }> = {
    current: { label: 'Текущая', color: 'bg-emerald-100 text-emerald-800' },
    past:    { label: 'Прошедшая', color: 'bg-gray-100 text-gray-600' },
    future:  { label: 'Будущая', color: 'bg-blue-100 text-blue-700' },
  }

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <h1 className="text-2xl font-bold text-gray-900">Петли времени</h1>
        <Link href={`/c/${slug}/sessions`} className="text-sm text-blue-600 hover:text-blue-800">
          Все сессии →
        </Link>
      </div>

      {loops && loops.length > 0 ? (
        <div className="grid grid-cols-[200px_1fr] gap-6">
          {/* Loop list */}
          <div className="space-y-1">
            {loops.map((loop) => {
              const st = statusLabel[loop.status] ?? statusLabel.past
              const isSelected = loop.number === selectedLoop?.number
              return (
                <Link
                  key={loop.id}
                  href={`/c/${slug}/loops?loop=${loop.number}`}
                  className={`block rounded-lg px-3 py-2.5 text-sm transition-colors ${
                    isSelected
                      ? 'bg-blue-50 border border-blue-200 text-blue-900'
                      : 'hover:bg-gray-50 text-gray-700 border border-transparent'
                  }`}
                >
                  <div className="font-medium">Петля {loop.number}</div>
                  {loop.title && (
                    <div className="text-xs text-gray-500 mt-0.5 truncate">{loop.title}</div>
                  )}
                  <span className={`mt-1 inline-block text-xs px-1.5 py-0.5 rounded-full ${st.color}`}>
                    {st.label}
                  </span>
                </Link>
              )
            })}
            <Link
              href={`/c/${slug}/loops/new`}
              className="block rounded-lg px-3 py-2 text-sm text-gray-400 hover:text-gray-600 border border-dashed border-gray-200 text-center mt-2"
            >
              + Добавить петлю
            </Link>
          </div>

          {/* Selected loop detail */}
          {selectedLoop && (
            <div className="space-y-5">
              <div className="rounded-xl border border-gray-200 bg-white p-5">
                <div className="flex items-start justify-between gap-4">
                  <div>
                    <div className="flex items-center gap-2 flex-wrap">
                      <h2 className="text-xl font-semibold text-gray-900">
                        Петля {selectedLoop.number}
                        {selectedLoop.title && ` — ${selectedLoop.title}`}
                      </h2>
                      {(() => {
                        const st = statusLabel[selectedLoop.status] ?? statusLabel.past
                        return (
                          <span className={`text-xs px-2 py-0.5 rounded-full font-medium ${st.color}`}>
                            {st.label}
                          </span>
                        )
                      })()}
                    </div>
                    {(selectedLoop.started_at || selectedLoop.ended_at) && (
                      <p className="mt-1 text-sm text-gray-500">
                        {selectedLoop.started_at && `Начало: ${selectedLoop.started_at}`}
                        {selectedLoop.started_at && selectedLoop.ended_at && ' · '}
                        {selectedLoop.ended_at && `Конец: ${selectedLoop.ended_at}`}
                      </p>
                    )}
                  </div>
                  <Link
                    href={`/c/${slug}/loops/${selectedLoop.id}/edit`}
                    className="text-sm text-gray-400 hover:text-gray-600 shrink-0"
                  >
                    Редактировать
                  </Link>
                </div>

                {selectedLoop.notes ? (
                  <div className="mt-4 border-t border-gray-100 pt-4">
                    <p className="text-sm text-gray-700 whitespace-pre-wrap">{selectedLoop.notes}</p>
                  </div>
                ) : (
                  <div className="mt-4 border-t border-gray-100 pt-4">
                    <Link
                      href={`/c/${slug}/loops/${selectedLoop.id}/edit`}
                      className="text-sm text-gray-400 hover:text-gray-600 italic"
                    >
                      + Добавить заметки о петле
                    </Link>
                  </div>
                )}
              </div>

              {/* Sessions */}
              <div>
                <div className="flex items-center justify-between mb-3">
                  <h3 className="text-sm font-semibold text-gray-600 uppercase tracking-wide">
                    Сессии ({sessions?.length ?? 0})
                  </h3>
                  <Link
                    href={`/c/${slug}/sessions/new?loop=${selectedLoop.number}`}
                    className="text-sm text-blue-600 hover:text-blue-800"
                  >
                    + Добавить
                  </Link>
                </div>

                {sessions && sessions.length > 0 ? (
                  <div className="space-y-1">
                    {sessions.map((s) => (
                      <Link
                        key={s.id}
                        href={`/c/${slug}/sessions/${s.id}`}
                        className="flex items-center gap-3 rounded-lg border border-gray-100 bg-white px-4 py-3 hover:border-gray-200 hover:bg-gray-50 transition-colors"
                      >
                        <span className="text-xs font-mono text-gray-400 w-8">#{s.session_number}</span>
                        <span className="text-sm font-medium text-gray-800 flex-1">
                          {s.title ?? `Сессия ${s.session_number}`}
                        </span>
                        {s.played_at && (
                          <span className="text-xs text-gray-400">
                            {new Date(s.played_at).toLocaleDateString('ru-RU', {
                              day: 'numeric', month: 'short', year: 'numeric',
                            })}
                          </span>
                        )}
                      </Link>
                    ))}
                  </div>
                ) : (
                  <div className="rounded-lg border border-dashed border-gray-200 py-8 text-center">
                    <p className="text-sm text-gray-400">Нет сессий в этой петле</p>
                    <Link
                      href={`/c/${slug}/sessions/new?loop=${selectedLoop.number}`}
                      className="mt-2 inline-block text-sm text-blue-600 hover:text-blue-800"
                    >
                      Добавить первую
                    </Link>
                  </div>
                )}
              </div>

              {/* Chronicles */}
              {chronicles && chronicles.length > 0 && (
                <div>
                  <h3 className="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-3">
                    Хроники
                  </h3>
                  <div className="space-y-1">
                    {(chronicles as any[]).map((c) => (
                      <div
                        key={c.id}
                        className="flex items-center gap-3 rounded-lg border border-gray-100 bg-white px-4 py-3"
                      >
                        {c.game_date && (
                          <span className="text-xs text-gray-400 w-16 shrink-0">{c.game_date}</span>
                        )}
                        <span className="text-sm text-gray-800 flex-1">{c.title}</span>
                        {c.nodes && (
                          <Link
                            href={`/c/${slug}/catalog/${c.node_id}`}
                            className="text-xs text-blue-500 hover:text-blue-700 shrink-0"
                          >
                            {(c.nodes as any).title}
                          </Link>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}
        </div>
      ) : (
        <div className="rounded-xl border-2 border-dashed border-gray-200 bg-white py-16 text-center">
          <div className="text-4xl mb-3">🔄</div>
          <p className="text-lg font-semibold text-gray-600">Петли ещё не созданы</p>
          <p className="mt-1 text-sm text-gray-400 max-w-sm mx-auto">
            Добавь первую петлю — задай номер, название и заметки о том, что в ней происходило
          </p>
          <Link
            href={`/c/${slug}/loops/new`}
            className="mt-4 inline-flex items-center gap-1 rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700"
          >
            + Создать петлю
          </Link>
        </div>
      )}
    </div>
  )
}
